generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USERS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  headline      String? // "Building 6 things at once"
  website       String?
  github        String?
  twitter       String?

  // Delivery preferences
  timezone     String       @default("America/New_York")
  activeStart  String       @default("09:00") // HH:mm format
  activeEnd    String       @default("23:00")
  deliveryMode DeliveryMode @default(SMART) // SMART | IMMEDIATE | DIGEST

  // Thinking profile (populated by pattern analysis)
  thinkingProfile ThinkingProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  tickets   Ticket[]
  responses Response[]
  comments  Comment[]
  artifacts TicketArtifact[]

  // Social
  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendReceiver")

  // Agent
  agentProxies AgentProxy[] @relation("AgentOwner")

  // Projects
  projects Project[]

  // Voice & Communication
  voiceProfile VoiceProfile?

  // Prompt dumps for matching
  promptDumps PromptDump[]

  // Interests (public profile)
  interests UserInterest[]

  // Match suggestions
  matchesAsUser1 Match[] @relation("MatchUser1")
  matchesAsUser2 Match[] @relation("MatchUser2")

  // Delivery queue
  deliveryQueue SmartDelivery[]
}

enum DeliveryMode {
  SMART // Smart timing based on active windows
  IMMEDIATE // Send immediately
  DIGEST // Daily digest at preferred time
}

// ============================================
// TICKETS (core communication unit)
// ============================================

model Ticket {
  id      String  @id @default(cuid())
  title   String
  content String // raw content, human-written
  summary String? // AI-generated summary (2 sentences max)

  type       TicketType       @default(DECISION)
  status     TicketStatus     @default(OPEN)
  visibility TicketVisibility @default(PRIVATE)

  // Metadata
  businessValue BusinessValue?
  riskLevel     RiskLevel?
  tags          String         @default("[]") // JSON array of tags

  // Agent attribution
  createdByAgent Boolean   @default(false)
  agentProxyId   String? // which agent created this
  approvedBy     String? // human who approved agent-created ticket
  approvedAt     DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // Bridge context (for private coordination between specific users)
  bridgeId String?
  bridge   Bridge? @relation(fields: [bridgeId], references: [id])

  responses Response[]
  artifacts TicketArtifact[]

  // Project link
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  // Social engagement (public tickets)
  likes     Int @default(0)
  bookmarks Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([authorId])
  @@index([projectId])
  @@index([visibility, status])
  @@index([type, status])
  @@index([createdAt])
}

enum TicketType {
  DECISION // Requires positions from parties
  INFO // One-way information, no response expected
  PROPOSAL // Proposed action, needs approval
  STATUS // Status update on ongoing work
  PUBLIC // Public post — anyone can comment
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  IN_MEDIATION // Multiple positions, needs resolution
  RESOLVED
  ARCHIVED
}

enum TicketVisibility {
  PRIVATE // Only bridge members
  FRIENDS // Visible to friends
  PUBLIC // Visible to everyone
}

model TicketArtifact {
  id      String       @id @default(cuid())
  kind    ArtifactKind @default(LINK)
  title   String
  uri     String?
  summary String?

  // JSON metadata for manifests, receipts, file hashes, paths, and external IDs.
  metadata String @default("{}")

  // Optional ContextClaw receipt fields for ticket-level spend/context display.
  provider           String?
  model              String?
  inputTokens        Int?
  outputTokens       Int?
  contextSavedTokens Int?
  costUsd            Float?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([kind])
  @@index([createdById])
}

enum ArtifactKind {
  LINK
  FILE
  NOTE
  CONTEXTCLAW_MANIFEST
  CONTEXTCLAW_RECEIPT
}

enum BusinessValue {
  REVENUE
  COST_SAVINGS
  GROWTH
  LEARNING
  COMMUNITY
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================
// RESPONSES & COMMENTS
// ============================================

model Response {
  id       String           @id @default(cuid())
  content  String
  position ResponsePosition @default(NEUTRAL)

  // Agent attribution
  createdByAgent Boolean   @default(false)
  agentProxyId   String?
  approvedBy     String?
  approvedAt     DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  comments Comment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ticketId])
  @@index([authorId])
}

enum ResponsePosition {
  AGREE
  DISAGREE
  COUNTER_PROPOSAL
  NEUTRAL
  QUESTION
}

model Comment {
  id      String @id @default(cuid())
  content String

  // Agent attribution
  createdByAgent Boolean   @default(false)
  agentProxyId   String?
  approvedBy     String?
  approvedAt     DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  responseId String
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([responseId])
}

// ============================================
// BRIDGES (private coordination spaces)
// ============================================

model Bridge {
  id   String @id @default(cuid())
  name String // e.g. "Builder One + Reviewer Two — Demo Project"

  members BridgeMember[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BridgeMember {
  id   String     @id @default(cuid())
  role BridgeRole @default(MEMBER)

  userId   String
  bridgeId String
  bridge   Bridge @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, bridgeId])
}

enum BridgeRole {
  OWNER
  MEMBER
  AGENT // Agent-only participant
}

// ============================================
// SOCIAL
// ============================================

model Friendship {
  id     String           @id @default(cuid())
  status FriendshipStatus @default(PENDING)

  requesterId String
  requester   User   @relation("FriendRequester", fields: [requesterId], references: [id])

  receiverId String
  receiver   User   @relation("FriendReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model UserInterest {
  id       String  @id @default(cuid())
  name     String // e.g. "agent coordination", "ML", "crypto"
  category String? // e.g. "technology", "business", "science"

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([name])
}

// ============================================
// AGENT SYSTEM
// ============================================

model AgentProxy {
  id          String  @id @default(cuid())
  name        String // e.g. "Conductor", "Review Agent"
  description String?

  // Auth
  apiKey String @unique @default(cuid())

  // Permissions
  canCreateTickets Boolean @default(true)
  canRespond       Boolean @default(true)
  canComment       Boolean @default(true)
  requiresApproval Boolean @default(true) // human must approve before posting

  ownerId String
  owner   User   @relation("AgentOwner", fields: [ownerId], references: [id])

  // Queued actions waiting for approval
  pendingActions AgentAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model AgentAction {
  id     String            @id @default(cuid())
  type   AgentActionType
  status AgentActionStatus @default(PENDING)

  // The action payload (JSON)
  payload String // JSON: {ticketId?, title?, content?, responseId?, position?}

  // Result
  resultId String? // ID of created ticket/response/comment after approval

  agentProxyId String
  agentProxy   AgentProxy @relation(fields: [agentProxyId], references: [id])

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([agentProxyId, status])
}

enum AgentActionType {
  CREATE_TICKET
  CREATE_RESPONSE
  CREATE_COMMENT
  EDIT_TICKET
}

enum AgentActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ============================================
// MATCHING (cofounder discovery)
// ============================================

model ThinkingProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Pattern-derived scores
  breadthScore       Float? // How many domains they work across
  depthScore         Float? // How deep they go in each domain
  synthesisScore     Float? // Cross-domain connection ability
  velocityScore      Float? // How fast they ship
  strategicAlignment Float? // Strategic timing orientation

  // Domain map
  domains String @default("[]") // JSON array of domains
  bridges String @default("[]") // JSON array of cross-domain connections

  // Build style
  projectCount Int? // Active projects
  soloVsTeam   Float? // 0 = pure solo, 1 = pure team
  agentUsage   Float? // How much they use AI agents (0-1)

  // Passion intensity (from prompt dump volume + frequency)
  passionIntensity Float? // 0-1 derived from prompt frequency in domains

  // Raw analysis (JSON blob from pattern engine)
  rawAnalysis String?

  analyzedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ============================================
// VOICE HANDSHAKE (communication preferences)
// ============================================

model VoiceProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Self-reported preferences (from onboarding / handshake)
  prefersLength     CommLength    @default(MEDIUM) // SHORT | MEDIUM | LONG
  prefersStructure  CommStructure @default(MIXED) // BULLETS | PROSE | MIXED
  prefersBottomLine Boolean       @default(true) // Bottom line first?
  prefersContext    Boolean       @default(true) // Include reasoning?
  prefersFormality  Formality     @default(CASUAL) // FORMAL | CASUAL | MATCH_MINE
  customNotes       String? // Freeform "here's how I like to be talked to"

  // AI-derived from their own writing patterns
  detectedTone     String? // e.g. "direct", "analytical", "conversational"
  avgMessageLength Int? // words per message
  usesEmoji        Boolean @default(false)
  usesCodeBlocks   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CommLength {
  SHORT // 1-3 sentences
  MEDIUM // 1-2 paragraphs
  LONG // Detailed with full context
}

enum CommStructure {
  BULLETS // Bullet points / lists
  PROSE // Flowing paragraphs
  MIXED // Whatever fits
}

enum Formality {
  FORMAL // Professional, structured
  CASUAL // Relaxed, conversational
  MATCH_MINE // Mirror my own style
}

// Per-collaboration voice adaptation
// When user A writes to user B, apply B's preferences
model CollaborationVoice {
  id String @id @default(cuid())

  // Who is being adapted TO (the recipient's preferences)
  forUserId  String
  // Who is doing the writing (whose agent adapts)
  fromUserId String

  // Override preferences for this specific pair
  overrideLength     CommLength?
  overrideStructure  CommStructure?
  overrideFormality  Formality?
  customInstructions String? // "Include code examples for this collaborator"

  // Learned from interaction history
  interactionCount Int       @default(0)
  lastCalibrated   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([forUserId, fromUserId])
}

// ============================================
// PROMPT DUMPS (cofounder matching data)
// ============================================

model PromptDump {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Source
  source   PromptSource
  filename String? // Original filename

  // Analysis state
  status       DumpStatus @default(UPLOADED)
  totalPrompts Int? // How many prompts in this dump
  dateRange    String? // e.g. "2024-01 to 2026-04"

  // Pattern analysis results (stored as JSON)
  domainBreakdown  String? // JSON: {"ML": 230, "web dev": 180, ...}
  passionScores    String? // JSON: {"ML": 0.92, "crypto": 0.34, ...}
  thinkingPatterns String? // JSON: pattern engine raw output
  crossDomainLinks String? // JSON: [{"from": "ML", "to": "retail", "count": 15}]

  // We do NOT store raw prompts — only analysis output
  rawStored Boolean @default(false) // Always false in production

  analyzedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

enum PromptSource {
  CHATGPT_EXPORT
  CLAUDE_EXPORT
  CUSTOM_JSON
  MANUAL_ENTRY
}

enum DumpStatus {
  UPLOADED
  ANALYZING
  COMPLETE
  FAILED
}

model Match {
  id    String @id @default(cuid())
  score Float // 0-100 compatibility score

  // Why this match
  rationale String // Human-readable explanation

  // Complementary dimensions
  sharedDomains     String @default("[]") // JSON array of shared domains
  complementaryGaps String @default("[]") // JSON array of complementary gaps
  thinkingOverlap   Float // How similarly they think (0-1)
  domainDiversity   Float // How different their domains are (0-1)

  status MatchStatus @default(SUGGESTED)

  user1Id String
  user1   User   @relation("MatchUser1", fields: [user1Id], references: [id])

  user2Id String
  user2   User   @relation("MatchUser2", fields: [user2Id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
}

enum MatchStatus {
  SUGGESTED
  VIEWED
  CONNECTED // Both accepted
  DISMISSED // One or both dismissed
}

// ============================================
// SMART DELIVERY
// ============================================

model SmartDelivery {
  id String @id @default(cuid())

  // What to deliver
  type      SmartDeliveryType
  contentId String // ticketId or responseId or matchId
  preview   String // 2-sentence summary for quick scan

  // Delivery timing
  scheduledFor DateTime? // When smart engine decided to deliver
  deliveredAt  DateTime? // When actually delivered
  readAt       DateTime? // When user opened it

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, deliveredAt])
  @@index([scheduledFor])
}

enum SmartDeliveryType {
  NEW_TICKET
  NEW_RESPONSE
  NEW_COMMENT
  MATCH_SUGGESTION
  AGENT_ACTION_PENDING
  FRIEND_REQUEST
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id String @id @default(cuid())

  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    String  @default("{}")
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}

// ============================================
// PROJECTS (Kickstarter-style collaboration)
// ============================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String
  status      ProjectStatus @default(ACTIVE)
  repoUrl     String?
  websiteUrl  String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  tickets      Ticket[]
  contributors ProjectContributor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model ProjectContributor {
  id        String   @id @default(cuid())
  role      String   @default("contributor")
  userId    String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([userId, projectId])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}
